{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-vcpkg-release",
      "displayName": "Windows Release with vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_MODE": "ON",
        "GSPICE_ENABLE_KLU": "ON",
        "GSPICE_REQUIRE_KLU": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
