VACASK transient reference: one millisecond RC step

ground 0
load "resistor.osdi"
load "capacitor.osdi"

model resistor resistor
model capacitor capacitor
model vsource vsource

v1 (in 0) vsource type="pulse" val0=0 val1=1 delay=1m rise=1u fall=1u width=10m period=20m
r1 (in out) resistor r=1k
c1 (out 0) capacitor c=1u

control
  abort always
  options rawfile="ascii" strictsave=0 reltol=3e-4 vntol=100n abstol=1e-12
  options tran_method="gear" tran_lteratio=1
  analysis tran_ref tran stop=5m step=10u maxstep=20u icmode="op"
endc
